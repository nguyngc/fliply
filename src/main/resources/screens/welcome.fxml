<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.control.MenuButton?>
<?import javafx.scene.control.MenuItem?>

<VBox xmlns="http://javafx.com/javafx/24.0.1"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="controller.WelcomeController"
      alignment="CENTER"
      prefWidth="375.0"
      prefHeight="750.0"
      style="-fx-background-color: #D9F4F1;"
      stylesheets="@../styles/style.css">

    <padding>
        <Insets top="24" right="24" bottom="50" left="24"/>
    </padding>

    <HBox alignment="TOP_RIGHT">
        <Region HBox.hgrow="ALWAYS"/>
        <MenuButton fx:id="languageMenuButton"
                    text="%language.current"
                    style="-fx-background-color: white; -fx-background-radius: 12; -fx-cursor: hand;">
            <items>
                <MenuItem text="English" onAction="#switchToEnglish"/>
                <MenuItem text="Finnish" onAction="#switchToFinnish"/>
                <MenuItem text="Korea" onAction="#switchToKorea"/>
                <MenuItem text="Laos" onAction="#switchToLaos"/>
                <MenuItem text="Tiếng Việt" onAction="#switchToVietnamese"/>
            </items>
        </MenuButton>
    </HBox>

    <Region prefHeight="100"/>

    <VBox alignment="CENTER" spacing="12">
        <ImageView fitHeight="200.0" fitWidth="322.0" pickOnBounds="true" preserveRatio="true">
            <image>
                <Image url="@../images/welcome_image.png"/>
            </image>
        </ImageView>

        <Label fx:id="titleLabel"
               styleClass="title-label"
               text="%welcome.title"/>

        <Label fx:id="subtitleLabel"
               styleClass="subtitle-label"
               text="%welcome.subtitle"
               textAlignment="CENTER"
               wrapText="true"/>
    </VBox>

    <HBox alignment="BOTTOM_CENTER" spacing="12">
        <padding>
            <Insets top="18"/>
        </padding>

        <Button fx:id="registerButton"
                prefWidth="140.0"
                text="%welcome.register"
                mnemonicParsing="false"
                onAction="#goRegister"/>

        <Button fx:id="loginButton"
                prefWidth="140.0"
                text="%welcome.login"
                mnemonicParsing="false"
                onAction="#goLogin"/>
    </HBox>

    <Region prefHeight="150"/>

</VBox>