<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.layout.*?>
<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="controller.AccountHelpController"
            prefWidth="375" prefHeight="750"
            style="-fx-background-color: #F6F7FB;">

    <top>
        <fx:include fx:id="header" source="../components/header.fxml"/>
    </top>

    <center>
        <ScrollPane fitToWidth="true" hbarPolicy="NEVER"
                    style="-fx-background-color: transparent; -fx-background: transparent;">
            <content>
                <VBox spacing="14">
                    <padding>
                        <Insets top="18" right="18" bottom="18" left="18"/>
                    </padding>

                    <Label text="%help.title"
                           style="-fx-font-size: 20px; -fx-font-weight: 500; -fx-text-fill: #1F1F39;"/>

                    <VBox spacing="8"
                          style="-fx-background-color: white; -fx-background-radius: 18;">
                        <padding>
                            <Insets top="16" right="16" bottom="16" left="16"/>
                        </padding>

                        <Label fx:id="quickStartTitleLabel"
                               wrapText="true"
                               style="-fx-font-size: 16px; -fx-font-weight: 600; -fx-text-fill: #1F1F39;"/>

                        <Label fx:id="quickStartBodyLabel"
                               wrapText="true"
                               style="-fx-font-size: 14px; -fx-text-fill: rgba(0,0,0,0.68); -fx-font-weight: 400;"/>
                    </VBox>

                    <VBox spacing="8"
                          style="-fx-background-color: white; -fx-background-radius: 18;">
                        <padding>
                            <Insets top="16" right="16" bottom="16" left="16"/>
                        </padding>

                        <Label fx:id="roleGuideTitleLabel"
                               wrapText="true"
                               style="-fx-font-size: 16px; -fx-font-weight: 600; -fx-text-fill: #1F1F39;"/>

                        <Label fx:id="roleGuideBodyLabel"
                               wrapText="true"
                               style="-fx-font-size: 14px; -fx-text-fill: rgba(0,0,0,0.68); -fx-font-weight: 400;"/>
                    </VBox>

                    <VBox spacing="8"
                          style="-fx-background-color: white; -fx-background-radius: 18;">
                        <padding>
                            <Insets top="16" right="16" bottom="16" left="16"/>
                        </padding>

                        <Label fx:id="commonTasksTitleLabel"
                               wrapText="true"
                               style="-fx-font-size: 16px; -fx-font-weight: 600; -fx-text-fill: #1F1F39;"/>

                        <Label fx:id="commonTasksBodyLabel"
                               wrapText="true"
                               style="-fx-font-size: 14px; -fx-text-fill: rgba(0,0,0,0.68); -fx-font-weight: 400;"/>
                    </VBox>

                    <VBox spacing="8"
                          style="-fx-background-color: white; -fx-background-radius: 18;">
                        <padding>
                            <Insets top="16" right="16" bottom="16" left="16"/>
                        </padding>

                        <Label fx:id="faqTitleLabel"
                               wrapText="true"
                               style="-fx-font-size: 16px; -fx-font-weight: 600; -fx-text-fill: #1F1F39;"/>

                        <Label fx:id="faqBodyLabel"
                               wrapText="true"
                               style="-fx-font-size: 14px; -fx-text-fill: rgba(0,0,0,0.68); -fx-font-weight: 400;"/>
                    </VBox>
                </VBox>
            </content>
        </ScrollPane>
    </center>

    <bottom>
        <AnchorPane prefHeight="95">
            <children>
                <fx:include source="../components/menu.fxml"
                            AnchorPane.leftAnchor="0"
                            AnchorPane.rightAnchor="0"
                            AnchorPane.bottomAnchor="0"/>
            </children>
        </AnchorPane>
    </bottom>
</BorderPane>
